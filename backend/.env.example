# ---- Server ----
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ---- Database ----
MONGODB_URI=mongodb://127.0.0.1:27017/swara
MONGODB_TEST_URI=mongodb://127.0.0.1:27017/swara_test

# ---- Auth (CHANGE THESE IN PRODUCTION) ----
JWT_SECRET=please-change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false

# ---- CAPTCHA ----
CAPTCHA_SECRET=please-change-this-captcha-signing-secret
CAPTCHA_TTL_SECONDS=300

# ---- Seed admin (created by `npm run seed`) ----
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@swara.local
ADMIN_PASSWORD=Admin@12345

# ---- Storage / Logs (relative to backend/ or absolute) ----
DATA_DIR=../data
LOG_DIR=../logs
MAX_UPLOAD_MB=50

# ---- Cloudinary (optional) ----
# Leave blank to store uploaded media on local disk (default for local dev).
# Set all three to store uploads (and seed media) on Cloudinary instead — required
# for persistent media on hosts with an ephemeral filesystem (e.g. Render free tier).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Email / SMTP (for admin replies to contact messages) ----
# Leave SMTP_HOST blank to disable real sending (replies are logged in dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Vijayavipanchi <no-reply@vijayavipanchi.org>
