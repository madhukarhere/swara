# dependencies
node_modules/
**/node_modules/

# env
.env
.env.local
**/.env
!**/.env.example

# build output
backend/dist/
frontend/.next/
frontend/out/
**/dist/
**/build/
*.tsbuildinfo

# logs
logs/*.log
**/*.log

# local media (keep folder structure via .gitkeep)
data/**/*
!data/
!data/**/
!data/**/.gitkeep

# misc
.DS_Store
coverage/

# The user's global gitignore ignores any dir named "public"; our backend API
# public routes live in backend/src/routes/public — force them back in.
!backend/src/routes/public/
!backend/src/routes/public/**

# Next.js static assets also live under a "public" dir — keep them tracked.
!frontend/public/
!frontend/public/**
